{
  "manifest_version": 3,
  "name": "AI ChatNavigator",
  "version": "1.0.0",
  "description": "Real-time table of contents for AI chat platforms. Never get lost in long conversations again.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "js": [
        "content/adapters/chatgpt.js",
        "content/adapters/claude.js",
        "content/adapters/gemini.js",
        "content/adapters/grok.js",
        "content/observer.js",
        "content/sidebar.js",
        "content/content.js"
      ],
      "css": ["styles/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
